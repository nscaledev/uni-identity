# test/.env.example
#
# Template showing the variables written by `make integration-fixtures`.
# This file is committed; test/.env is gitignored.
#
# Normally test/.env is generated automatically:
#   make integration-install integration-fixtures   # writes test/.env.install then test/.env
#   make test-api                                  # reads test/.env
#
# To point the suite at an existing deployment without re-running fixtures:
#   KIND_SUFFIX=<suffix> make integration-fixtures test-api

# Identity service URL (set by hack/ci/install)
IDENTITY_BASE_URL=https://identity-<suffix>.127.0.0.1.nip.io

# Absolute path to the CA bundle written by hack/ci/setup-infra
IDENTITY_CA_CERT=/path/to/hack/ci/ca-bundle.pem

# Resource IDs created by hack/ci/fixtures
TEST_ORG_ID=
TEST_PROJECT_ID=
TEST_ADMIN_GROUP_ID=
TEST_USER_GROUP_ID=
TEST_ADMIN_SA_ID=
TEST_USER_SA_ID=

# Bearer token for the administrator service account
# (organization-scoped; full identity CRUD)
API_AUTH_TOKEN=
ADMIN_AUTH_TOKEN=

# Bearer token for the user service account
# (project-scoped; limited org-level access)
USER_AUTH_TOKEN=

# ─── Auth0 fixtures ──────────────────────────────────────────────────────────
#
# Tokens written here are consumed by the Auth0 exchange integration tests.
# All AUTH0_*_JWT_TOKEN and AUTH0_OPAQUE_TOKEN values (except the expired one)
# are minted automatically by hack/ci/fixtures and refreshed on every run.
#
# To enable Auth0 minting, export the credentials below (in your shell or via
# test/.env.install) BEFORE running `make integration-fixtures`:
#
#   AUTH0_DOMAIN              tenant domain (e.g. nscale-dev.uk.auth0.com)
#   AUTH0_AUDIENCE            primary audience (matches --auth0-audience)
#   AUTH0_CLIENT_ID           minting client
#   AUTH0_CLIENT_SECRET
#   AUTH0_USERNAME            active user; also written as AUTH0_EXPECTED_SUBJECT
#   AUTH0_PASSWORD
#
# Optional per-fixture credentials:
#
#   AUTH0_REALM               DB connection name (default Username-Password-Authentication)
#   AUTH0_SCOPE               default "openid profile email identity:token:exchange"
#   AUTH0_INACTIVE_USERNAME   inactive-user fixture
#   AUTH0_INACTIVE_PASSWORD
#   AUTH0_WRONG_AUDIENCE      wrong-audience fixture (same tenant, different aud)
#   AUTH0_WRONG_ISSUER_DOMAIN        wrong-issuer fixture (different tenant; audience
#   AUTH0_WRONG_ISSUER_CLIENT_ID     is shared with AUTH0_AUDIENCE)
#   AUTH0_WRONG_ISSUER_CLIENT_SECRET
#
# AUTH0_EXPIRED_JWT_TOKEN is the only Auth0 fixture not auto-minted: an
# expired token stays expired forever, so mint it once via
#   echo "AUTH0_EXPIRED_JWT_TOKEN=$(go run ./hack/auth0)" >> test/.env.install
# and the fixtures script will pass it through.

# Tokens auto-minted by hack/ci/fixtures (and AUTH0_EXPIRED_JWT_TOKEN passed
# through from env). Each fixture whose minting config is missing is left
# blank and the matching Ginkgo case Skips.
AUTH0_VALID_JWT_TOKEN=
AUTH0_INACTIVE_USER_JWT_TOKEN=
AUTH0_WRONG_AUDIENCE_JWT_TOKEN=
AUTH0_WRONG_ISSUER_JWT_TOKEN=
AUTH0_OPAQUE_TOKEN=
AUTH0_EXPIRED_JWT_TOKEN=
AUTH0_EXPECTED_SUBJECT=

# Optional UNI token covering the same human identity as AUTH0_USERNAME, used
# by the (currently Skipped) dual-source equivalence tests.
AUTH0_EQUIVALENT_UNI_TOKEN=
